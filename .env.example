# Database (Supabase / Neon / Railway — must be hosted Postgres)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Redis (Upstash or other)
REDIS_URL="redis://default:password@host:6379"

# Reservation window in minutes (default 10)
RESERVATION_MINUTES=10
